# CarbonCringe Environment Variables

# NVIDIA Nemotron API Key
# Get yours at: https://build.nvidia.com
# Required for AI roast generation, footprint analysis, and personalized suggestions
NVIDIA_API_KEY=your_nvidia_api_key_here

# Optional: Override the NVIDIA base URL (defaults to https://integrate.api.nvidia.com/v1)
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional: Override the model ID (defaults to nvidia/nemotron-ultra-253b-v1)
# NVIDIA_MODEL_ID=nvidia/nemotron-ultra-253b-v1
